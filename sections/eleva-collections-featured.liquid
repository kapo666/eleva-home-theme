{% assign eleva_collection_titles = 'Accessori Bagno Moderni|Cucina e Tavola|Organizzazione Casa|Decorazione Casa Moderna|Illuminazione Casa Design|Tessili Casa Moderni' | split: '|' %}
{% assign eleva_collection_links = '/collections/accessori-bagno|/collections/cucina-tavola|/collections/organizzazione-casa|/collections/decorazione-casa|/collections/illuminazione-casa|/collections/tessili-casa' | split: '|' %}
{% assign eleva_collection_handles = 'accessori-bagno|cucina-tavola|organizzazione-casa|decorazione-casa|illuminazione-casa|tessili-casa' | split: '|' %}
{% assign eleva_collection_microcopy = 'Dispenser, portasapone e set bagno moderni|Organizer cucina, portaspezie e utensili design|Contenitori, scatole e soluzioni salvaspazio|Vasi, quadri e complementi d’arredo moderni|Lampade LED e luci design per ogni ambiente|Cuscini, coperte e tappeti moderni' | split: '|' %}
{% assign eleva_collection_alt = 'Accessori bagno moderni ELEVA HOME|Cucina e tavola con accessori moderni|Organizzazione casa con contenitori e soluzioni salvaspazio|Decorazione casa moderna con complementi d’arredo|Illuminazione casa design|Tessili casa moderni' | split: '|' %}
{% assign eleva_collection_link_titles = 'Scopri accessori bagno moderni|Scopri accessori cucina e tavola|Scopri soluzioni per organizzazione casa|Scopri decorazione casa moderna|Scopri illuminazione casa design|Scopri tessili casa moderni' | split: '|' %}

<section class="eleva-homepage eleva-collections-section eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head eleva-reveal">
      <p class="eleva-eyebrow">Collezioni</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-collections-grid">
      {% for title in eleva_collection_titles %}
        {% assign card_handle = eleva_collection_handles[forloop.index0] %}
        {% assign card_collection = collections[card_handle] %}
        {% assign card_link = eleva_collection_links[forloop.index0] %}
        {% assign card_title = title %}
        {% assign card_microcopy = eleva_collection_microcopy[forloop.index0] %}
        {% assign card_image_alt = eleva_collection_alt[forloop.index0] %}
        {% assign card_link_title = eleva_collection_link_titles[forloop.index0] %}
        {% if card_collection != blank and card_collection.url != blank %}
          {% assign card_link = card_collection.url %}
        {% endif %}
        {% assign card_image = blank %}
        {% if card_collection != blank %}
          {% assign card_image = card_collection.image %}
          {% if card_image == blank %}
            {% assign card_image = card_collection.featured_image %}
          {% endif %}
        {% endif %}
        <a class="eleva-collection-card eleva-card eleva-reveal{% cycle '', ' eleva-reveal--delay-1', ' eleva-reveal--delay-2', ' eleva-reveal--delay-3', ' eleva-reveal--delay-4', ' eleva-reveal--delay-2' %}" href="{{ card_link }}" title="{{ card_link_title }}">
          {% if card_image != blank %}
            <div class="eleva-collection-card__media">
              {{
                card_image
                | image_url: width: 1200
                | image_tag:
                  class: 'eleva-collection-card__image',
                  widths: '320, 480, 640, 900, 1200',
                  sizes: '(min-width: 990px) 33vw, 50vw',
                  loading: 'lazy',
                  alt: card_image_alt
              }}
            </div>
          {% else %}
            <div class="eleva-collection-card__media eleva-collection-card__media--placeholder">
              <div class="eleva-collection-card__placeholder">
                <span class="eleva-eyebrow">{{ forloop.index | prepend: '0' }}</span>
                <strong>{{ card_title }}</strong>
              </div>
            </div>
          {% endif %}
          <div class="eleva-collection-card__body">
            <h3 class="eleva-collection-card__title">{{ card_title }}</h3>
            <p class="eleva-collection-card__microcopy">{{ card_microcopy }}</p>
            <span class="eleva-collection-card__link">Esplora</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Esplora le Nostre Collezioni di Accessori Casa"
    }
  ],
  "presets": [
    {
      "name": "ELEVA Collections"
    }
  ]
}
{% endschema %}
