<section class="eleva-homepage eleva-collections-section eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-collections-grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        {% assign image = collection.image | default: collection.featured_image %}
        {% assign fallback_title = block.settings.fallback_title %}
        {% assign card_title = collection.title | default: fallback_title %}
        {% assign card_url = collection.url | default: routes.collections_url %}
        <a class="eleva-collection-card eleva-card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="eleva-collection-card__media{% if image == blank %} eleva-collection-card__media--placeholder{% endif %}">
            {% if image != blank %}
              {{
                image
                | image_url: width: 900
                | image_tag:
                  class: 'eleva-collection-card__image',
                  widths: '320, 480, 640, 900',
                  sizes: '(min-width: 990px) 33vw, 50vw',
                  loading: 'lazy',
                  alt: collection.title
              }}
            {% else %}
              <div class="eleva-collection-card__placeholder">
                <span class="eleva-eyebrow">{{ forloop.index | prepend: '0' }}</span>
                <strong>{{ card_title }}</strong>
              </div>
            {% endif %}
          </div>
          <div class="eleva-collection-card__body">
            <h3 class="eleva-collection-card__title">{{ card_title }}</h3>
            <span class="eleva-collection-card__link">Esplora</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Featured Collections",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Fallback title",
          "default": "Collezione ELEVA"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collezioni"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Esplora le nostre collezioni"
    }
  ],
  "presets": [
    {
      "name": "ELEVA Featured Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Accessori Bagno"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Cucina e Tavola"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Organizzazione Casa"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Decorazione Casa"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Illuminazione Casa"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "fallback_title": "Tessili Casa"
          }
        }
      ]
    }
  ]
}
{% endschema %}
