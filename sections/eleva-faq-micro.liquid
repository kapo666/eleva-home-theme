<section class="eleva-homepage eleva-faq-section eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head eleva-reveal">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-faq-list">
      {% for block in section.blocks %}
        <details class="eleva-faq-item eleva-card eleva-card--soft eleva-reveal{% case forloop.index %}{% when 2 %} eleva-reveal--delay-1{% when 3 %} eleva-reveal--delay-2{% when 4 %} eleva-reveal--delay-3{% endcase %}" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="eleva-faq-item__summary">
            <h3 class="eleva-faq-item__question">{{ block.settings.question }}</h3>
            <span class="eleva-faq-item__icon" aria-hidden="true"></span>
          </summary>
          <div class="eleva-faq-item__answer">
            <p class="eleva-text eleva-muted">{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SUPPORTO"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Domande frequenti"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Quali sono i tempi di consegna per gli accessori casa?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Spediamo gli ordini in 24-48h. La consegna richiede 3-5 giorni lavorativi in tutta Italia. Riceverai il tracking via email."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELEVA FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Quali sono i tempi di consegna per gli accessori casa?",
            "answer": "Spediamo gli ordini in 24-48h. La consegna richiede 3-5 giorni lavorativi in tutta Italia. Riceverai il tracking via email."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Posso restituire prodotti aperti? Come funziona il reso?",
            "answer": "Sì. Hai 30 giorni per restituire qualsiasi prodotto, anche se è stato aperto e provato. Il reso è gratuito."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Come selezionate gli accessori casa? Sono di qualità?",
            "answer": "Ogni prodotto è selezionato e controllato dal nostro team prima di essere proposto su ELEVA HOME. La garanzia di 2 anni è inclusa."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Come posso contattare l’assistenza?",
            "answer": "Scrivi a assistenza@elevahome.it. Ti rispondiamo entro 24h con supporto chiaro e dedicato."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Spedite in tutta Italia? Ci sono costi extra?",
            "answer": "Sì, spediamo in tutta Italia. La spedizione è gratuita sopra 50€ e i costi sono sempre mostrati chiaramente prima del checkout."
          }
        }
      ]
    }
  ]
}
{% endschema %}
