<section class="eleva-collection-page eleva-collection-faq eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-faq-list">
      {% for block in section.blocks %}
        <details class="eleva-faq-item eleva-card eleva-card--soft" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="eleva-faq-item__summary">
            <h3 class="eleva-faq-item__question">{{ block.settings.question }}</h3>
            <span class="eleva-faq-item__icon" aria-hidden="true"></span>
          </summary>
          <div class="eleva-faq-item__answer">
            <p class="eleva-text eleva-muted">{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Collection FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SUPPORTO"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Domande frequenti sugli accessori bagno"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Quali materiali sono migliori per gli accessori bagno?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Ceramica, vetro e acciaio inox sono tra i materiali più adatti perché resistenti all’umidità, facili da pulire e coerenti con un bagno moderno."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELEVA Collection FAQ",
      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]
}
{% endschema %}
