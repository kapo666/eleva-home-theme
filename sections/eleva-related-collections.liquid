<section class="eleva-collection-page eleva-related-collections eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-related-collections__grid">
      {% for block in section.blocks %}
        {% assign card_collection = block.settings.related_collection %}
        {% assign card_title = block.settings.fallback_title %}
        {% assign card_link = block.settings.fallback_link %}
        {% assign card_image = blank %}

        {% if card_collection != blank %}
          {% assign card_title = card_collection.title %}
          {% assign card_link = card_collection.url %}
          {% assign card_image = card_collection.image %}
          {% if card_image == blank %}
            {% assign card_image = card_collection.featured_image %}
          {% endif %}
        {% endif %}

        <a class="eleva-related-collections__card eleva-card eleva-card--soft" href="{{ card_link }}" {{ block.shopify_attributes }}>
          <div class="eleva-related-collections__media{% if card_image == blank %} eleva-related-collections__media--placeholder{% endif %}">
            {% if card_image != blank %}
              {{
                card_image
                | image_url: width: 900
                | image_tag:
                  class: 'eleva-related-collections__image',
                  widths: '240, 360, 520, 720, 900',
                  sizes: '(min-width: 990px) 25vw, 50vw',
                  loading: 'lazy',
                  alt: card_title
              }}
            {% else %}
              <div class="eleva-related-collections__placeholder" aria-hidden="true">
                <span>{{ card_title }}</span>
              </div>
            {% endif %}
          </div>
          <div class="eleva-related-collections__body">
            <h3 class="eleva-related-collections__title">{{ card_title }}</h3>
            <span class="eleva-related-collections__link">Esplora</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Related Links",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "COLLEZIONI CORRELATE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Scopri altri ambienti ELEVA"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "related_collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Fallback title",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "fallback_link",
          "label": "Fallback link",
          "default": "/collections/example"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELEVA Related Links",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
