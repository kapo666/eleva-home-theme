<section class="eleva-homepage eleva-brand-proof-section eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-proof-grid">
      {% for block in section.blocks %}
        <article class="eleva-proof-card eleva-card eleva-card--soft" {{ block.shopify_attributes }}>
          <h3 class="eleva-proof-card__title">{{ block.settings.title }}</h3>
          <p class="eleva-text eleva-muted">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Brand Proof",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Perché ELEVA HOME"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Perché scegliere ELEVA HOME"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Selezione curata"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Prodotti scelti per funzionalità, estetica e uso quotidiano."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELEVA Brand Proof",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Selezione curata",
            "text": "Prodotti scelti per funzionalità, estetica e uso quotidiano."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Design per ogni ambiente",
            "text": "Soluzioni per cucina, bagno, organizzazione, tessili e decorazione."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Esperienza semplice",
            "text": "Navigazione chiara, pagamenti sicuri e assistenza dedicata."
          }
        }
      ]
    }
  ]
}
{% endschema %}
