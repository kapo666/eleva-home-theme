<section class="eleva-homepage eleva-brand-proof-section eleva-section">
  <div class="eleva-container">
    <div class="eleva-section-head eleva-reveal">
      <p class="eleva-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eleva-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="eleva-proof-grid">
      {% for block in section.blocks %}
        <article class="eleva-proof-card eleva-card eleva-card--soft eleva-reveal{% case forloop.index %}{% when 2 %} eleva-reveal--delay-1{% when 3 %} eleva-reveal--delay-2{% endcase %}" {{ block.shopify_attributes }}>
          <span class="eleva-proof-card__marker" aria-hidden="true"></span>
          <h3 class="eleva-proof-card__title">{{ block.settings.title }}</h3>
          <p class="eleva-text eleva-muted">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Quality",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ELEVA HOME"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Qualità e Selezione: Il Nostro Impegno"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Selezione rigorosa"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Ogni prodotto è selezionato e testato personalmente dal nostro team per garantire funzionalità, estetica e durata nel tempo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELEVA Quality",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Selezione rigorosa",
            "text": "Ogni prodotto è selezionato e testato personalmente dal nostro team per garantire funzionalità, estetica e durata nel tempo."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Garanzia Estesa 2 Anni",
            "text": "2 anni di garanzia completa su tutti i prodotti, con sostituzione rapida in caso di difetti di fabbricazione."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Assistenza dedicata",
            "text": "Team di assistenza italiano disponibile via email. Rispondiamo entro 24h, anche durante il weekend."
          }
        }
      ]
    }
  ]
}
{% endschema %}
