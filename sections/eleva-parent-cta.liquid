<section class="eleva-subcollection-page eleva-parent-cta">
  <div class="eleva-container">
    <div class="eleva-parent-cta__inner">
      <p class="eleva-parent-cta__text">{{ section.settings.text }}</p>
      <a class="eleva-btn eleva-btn--primary eleva-parent-cta__button" href="{{ section.settings.button_link }}">
        {{ section.settings.button_label }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Parent CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Vuoi completare l’ambiente con altri dettagli morbidi?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Scopri tutti i Tessili Casa"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/tessili-casa"
    }
  ],
  "presets": [
    {
      "name": "ELEVA Parent CTA"
    }
  ]
}
{% endschema %}
