{% assign eleva_hero_heading_source = section.settings.heading | strip_html | strip %}
{% assign eleva_hero_display_heading = eleva_hero_heading_source %}
{% if eleva_hero_display_heading contains '—' %}
  {% assign eleva_hero_heading_parts = eleva_hero_display_heading | split: '—' %}
  {% assign eleva_hero_display_heading = eleva_hero_heading_parts.last | strip %}
{% endif %}
{% assign eleva_hero_line_one = eleva_hero_display_heading %}
{% assign eleva_hero_line_two = blank %}
{% if eleva_hero_display_heading contains 'Accessori Casa Moderni per una Casa Ordinata' %}
  {% assign eleva_hero_line_one = 'Accessori casa moderni' %}
  {% assign eleva_hero_line_two = 'per una casa ordinata' %}
{% endif %}

<section class="eleva-homepage eleva-hero-section">
  <div class="eleva-container">
    <div class="eleva-hero eleva-card eleva-card--soft{% if section.settings.hero_image != blank %} eleva-hero--with-image{% endif %}">
      <div class="eleva-hero__visual eleva-reveal eleva-reveal--delay-1">
        <div class="eleva-hero__visual-orb eleva-reveal eleva-reveal--delay-2" aria-hidden="true"></div>
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 1200
            | image_tag:
              class: 'eleva-hero__visual-image eleva-reveal eleva-reveal--delay-3',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 32rem, 100vw',
              loading: 'lazy',
              alt: 'Ambiente moderno ELEVA HOME con accessori casa e design minimal'
          }}
        {% else %}
          <div class="eleva-hero__visual-panel eleva-reveal eleva-reveal--delay-3" aria-hidden="true"></div>
        {% endif %}
      </div>
      <div class="eleva-hero__inner">
        <p class="eleva-eyebrow eleva-reveal">{{ section.settings.eyebrow }}</p>
        <p class="eleva-hero__brand eleva-reveal eleva-reveal--delay-1">ELEVA HOME</p>
        <h1 class="eleva-heading eleva-hero__title eleva-reveal eleva-reveal--delay-1">
          <span class="eleva-hero__title-line">{{ eleva_hero_line_one }}</span>
          {% if eleva_hero_line_two != blank %}
            <span class="eleva-hero__title-line">{{ eleva_hero_line_two }}</span>
          {% endif %}
        </h1>
        <p class="eleva-text eleva-muted eleva-hero__subtitle eleva-reveal eleva-reveal--delay-2">{{ section.settings.subheading }}</p>
        <a class="eleva-btn eleva-btn--primary eleva-hero__cta eleva-reveal eleva-reveal--delay-3" href="{{ section.settings.button_link | default: '/collections' }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELEVA Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SHOP ONLINE DESIGN PER LA CASA"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "ELEVA HOME — Accessori Casa Moderni per una Casa Ordinata ed Elegante"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Il tocco che trasforma gli spazi quotidiani in ambienti di ordine, comfort e stile."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Scopri le collezioni"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "ELEVA Hero"
    }
  ]
}
{% endschema %}
